# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Database ---
POSTGRES_USER=log_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=api_log_db
POSTGRES_PORT=5432

# --- Application ---
DB_DEVELOPMENT_MODE=false

# --- Host log directories (mounted into the container) ---
OCR_PROJECT_LOG_DIR=/path/to/your/logs/api
OCR_PROJECT_LOG_CLIENT=/path/to/your/logs/client
OCR_DOC_INVOICE=/path/to/your/logs/doc
